{
  "name": "@eth-optimism/tokenlist",
  "description": "[Optimism] token list",
  "version": "10.0.1761",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/ethereum-optimism/ethereum-optimism.github.io#readme",
  "license": "MIT",
  "author": "Optimism",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ethereum-optimism/ethereum-optimism.github.io.git"
  },
  "tsup": {
    "entry": [
      "index.ts",
      "optimism.tokenlist.json"
    ],
    "outDir": "dist",
    "format": [
      "esm",
      "cjs"
    ],
    "splitting": false,
    "sourcemap": true,
    "clean": true
  },
  "scripts": {
    "validate": "tsx ./bin/cli.ts validate",
    "generate": "tsx ./bin/cli.ts generate",
    "generate:ci": "pnpm generate --datadir ./data --outfile optimism.tokenlist.json",
    "build": "tsup",
    "build:ci": "pnpm generate:ci && pnpm tsup --dts",
    "release": "pnpm build:ci && npm publish",
    "test": "jest --detectOpenHandles",
    "lint:check": "eslint . --max-warnings=0",
    "lint:fix": "eslint --fix .",
    "lint": "pnpm lint:fix && pnpm lint:check",
    "start-bot": "tsx ./src/bot.ts",
    "typecheck": "tsc -p ./tsconfig.json --noEmit"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@types/glob": "^8.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "22.14.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^4.26.0",
    "@uniswap/token-lists": "^1.0.0-beta.32",
    "ajv": "^8.20.0",
    "ajv-formats": "^2.1.1",
    "commander": "^9.5.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsdoc": "^35.1.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-react": "^7.24.0",
    "eslint-plugin-unicorn": "^44.0.2",
    "ethers": "^6.16.0",
    "extract-zip": "^2.0.1",
    "glob": "^8.1.0",
    "jest": "^28.1.3",
    "jsonschema": "^1.5.0",
    "mocha": "^8.4.0",
    "node-fetch": "2.7.0",
    "octokit": "^3.1.2",
    "prettier": "^2.8.8",
    "ts-jest": "^29.4.11",
    "ts-mocha": "^10.0.0",
    "tsup": "^8.5.1",
    "tsx": "^3.14.0",
    "typescript": "^4.9.5",
    "@types/express": "^4.17.21",
    "express": "^4.20.0"
  },
  "packageManager": "pnpm@8.6.0",
  "engines": {
    "node": "^22.0.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/helpers": "7.26.10",
      "@babel/runtime": "7.26.10",
      "@octokit/request": "9.2.1",
      "@octokit/request-error": "6.1.7",
      "@octokit/webhooks": "12.0.3",
      "ajv": "8.20.0",
      "bn.js": "5.2.3",
      "body-parser": "1.20.3",
      "brace-expansion": "2.0.3",
      "cookie": "0.7.2",
      "cross-spawn": "7.0.5",
      "diff": "5.2.2",
      "esbuild": "0.25.0",
      "express": "4.20.0",
      "flatted": "3.4.2",
      "get-func-name": "2.0.2",
      "js-yaml": "4.1.1",
      "json5": "2.2.3",
      "jsonwebtoken": "9.0.2",
      "jws": "4.0.1",
      "lodash": "4.18.1",
      "micromatch": "4.0.8",
      "minimatch": "3.1.4",
      "nanoid": "3.3.8",
      "on-headers": "1.1.0",
      "path-to-regexp": "0.1.13",
      "picomatch": "2.3.2",
      "qs": "6.15.2",
      "rollup": "3.30.0",
      "semver": "7.5.2",
      "send": "0.19.0",
      "serialize-javascript": "7.0.5",
      "serve-static": "1.16.0",
      "tsup": "8.5.1",
      "undici": "6.24.0",
      "word-wrap": "1.2.5",
      "ws": "7.5.10",
      "yaml": "1.10.3"
    }
  }
}
